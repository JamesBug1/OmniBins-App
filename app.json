{
  "expo": {
    "name": "OmniApp",
    "slug": "OmniApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/omni.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/omni.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omniapp"
    },
    "android": {
      "package": "com.omniapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/omni.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "useNextNotificationFormat": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0115b3f9-2dea-48ef-86a8-650a0a1ea8f8"
      }
    }
  }
}
